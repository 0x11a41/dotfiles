#!/usr/bin/env fish

# =============================================================================
# WF-RECORDER CONFIGURATION
# =============================================================================
# 1. Output Format & Saving
set OUTPUT_FORMAT gif # Extension: mp4, mkv, webm, or gif
set OVERWRITE_FILE -y # "-y" to force overwrite without prompting, or "" to disable

# 2. Audio Settings
# Note: For GIFs, remove "-a" or set AUDIO_BACKEND to "" as GIFs don't support audio.
set RECORD_AUDIO "" # "-a" to record audio, "" to disable video-only
set AUDIO_DEVICE "" # Leave empty for default, or specify (e.g., "-a<device_name>")
set AUDIO_BACKEND "--audio-backend=pipewire" # Options: pulse, pipewire, etc.
set AUDIO_CODEC "" # e.g., "-C aac". Leave empty for default.

# 3. Video & Performance Tweaks
set CODEC "" # e.g., "-c libx264" or "-c gif". Leave empty for default.
set FRAMERATE "" # e.g., "-r 60" for a locked 60 FPS, or "" for variable
set MAX_BFRAMES "" # e.g., "-b 0" if your hardware doesn't support b-frames

# 4. Advanced Performance Optimizations
# By default, wf-recorder only saves a frame when the screen updates (Variable Refresh Rate).
# Turn this flag ON ("-D") to force continuous recording (bigger file size, smoother for editing).
set FORCE_CONSTANT_VRR "" # "-D" or "--no-damage" to force constant frames, "" for default optimization

# Force CPU encoding if your GPU/VAAPI drivers are causing black screens or errors
set DISABLE_GPU_BUFFERS "" # "--no-dmabuf" to force CPU encoding, "" for default GPU copy
# =============================================================================
# END OF WF-RECORDER CONFIGURATION
# =============================================================================

if test "$OUTPUT_FORMAT" = gif
    set RECORD_AUDIO ""
    set AUDIO_BACKEND ""
    set FORCE_CONSTANT_VRR ""
    set FMT mp4
else
    set FMT $OUTPUT_FORMAT
end

set SPEC $RECORD_AUDIO $AUDIO_DEVICE $AUDIO_BACKEND $AUDIO_CODEC $CODEC $FRAMERATE $MAX_BFRAMES $FORCE_CONSTANT_VRR $DISABLE_GPU_BUFFERS $OVERWRITE_FILE

set TERMINAL kitty

set FILE "$HOME/Videos/Screencasts/screencast-$(date +'%Y-%m-%d_%H%M%S').$FMT"
set LOGFILE "/tmp/recstat.log"
set monitors (hyprctl monitors | awk '/^Monitor/ { print $2 }')
set OPT $argv[1]

pkill -x fuzzel

if test -z "$argv"
    set opts

    if pidof wf-recorder >/dev/null
        set opts $opts stop
    end

    set opts $opts $monitors region configure

    set OPT (string join \n $opts | fuzzel --dmenu --hide-prompt --mesg='SUPER + F10 to stop')

    if test -z "$OPT"
        exit
    end
end

switch $OPT
    case configure
        $TERMINAL -e hx ~/.config/hypr/cast

    case stop
        if pidof wf-recorder >/dev/null
            pkill wf-recorder

            set RECORDED_VIDEO (head -n 1 $LOGFILE)
            set FINAL_FILENAME $RECORDED_VIDEO

            if test "$OUTPUT_FORMAT" = gif
                set FINAL_FILENAME (string replace -r '\.mp4$' '.gif' $RECORDED_VIDEO)
                ffmpeg -y -i "$RECORDED_VIDEO" -ss 00:00:00 -t 9 -vf "fps=12,scale=800:-1:flags=lanczos,split[s0][s1];[s0]palettegen[p];[s1][p]paletteuse" "$FINAL_FILENAME"
                rm "$RECORDED_VIDEO"
            end

            # set NOTIFY_RES (notify-send \
            #     -a "wf-recorder" \
            #     -i video-display \
            #     -h string:file_path:"$FINAL_FILENAME" \
            #     -A "open=Open Location" \
            #     "Recording Stopped" \
            #     "File saved to: $(basename $FINAL_FILENAME)")

            # if test "$NOTIFY_RES" = open
            #     nautilus "$FINAL_FILENAME"
            # end
        end

    case region
        set REGION (slurp)
        if test -z "$REGION"
            exit
        end
        echo "$FILE" >$LOGFILE
        pkill wf-recorder
        wf-recorder $SPEC -g "$REGION" -f "$FILE" >>$LOGFILE 2>&1 &

    case '*'
        if contains -- "$OPT" $monitors
            echo "$FILE" >$LOGFILE
            pkill wf-recorder

            wf-recorder $SPEC -o "$OPT" -f "$FILE" >>$LOGFILE 2>&1 &
        else
            echo "Error: '$OPT' is not a valid monitor or option."
            exit 1
        end
end
